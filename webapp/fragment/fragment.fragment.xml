<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">

    <Dialog
        id="fragment_id_taskDialog"
        draggable="true"
        resizable="true"
        stretch="false"
        horizontalScrolling="false"
        verticalScrolling="true"
        contentWidth="25rem"
        class="sapUiContentPadding">

        <content>
            <VBox width="100%" class="sapUiSmallMarginEnd">
                
                <f:SimpleForm
                    editable="true"
                    layout="ResponsiveGridLayout"
                    width="100%"
                    singleContainerFullSize="true"
                    labelSpanXL="12"
                    labelSpanL="12"
                    labelSpanM="12"
                    labelSpanS="12"
                    adjustLabelSpan="false">

                    <f:content>
                        <Label text="{i18n>label.employee.name}" required="true"/>
                        <Input
                            id="fragment_id_empName"
                            width="100%"
                            placeholder="{i18n>placeholder.employee.name}"
                            maxLength="50"
                            liveChange="View1_onEmpNameLiveChange"/>

                        <Label text="{i18n>label.employee.id}" required="true"/>
                        <Input
                            id="fragment_id_empId"
                            width="100%"
                            placeholder="{i18n>placeholder.employee.id}"
                            maxLength="20"
                            liveChange="View1_onLiveChange"/>

                        <Label text="{i18n>label.task.id}" required="true"/>
                        <Input
                            id="fragment_id_taskId"
                            width="100%"
                            placeholder="{i18n>placeholder.task.id}"
                            maxLength="50"
                            liveChange="View1_onLiveChange"/>

                        <Label text="{i18n>label.task.name}" required="true"/>
                        <Input
                            id="fragment_id_taskName"
                            width="100%"
                            placeholder="{i18n>placeholder.task.name}"
                            maxLength="100"
                            liveChange="View1_onLiveChange"/>

            <Label text="{i18n>label.start.date}" required="true"/>
<DatePicker
    id="fragment_id_startDate"
    width="100%"
    valueFormat="yyyy-MM-dd"
    displayFormat="dd/MM/yyyy"
    placeholder="{i18n>placeholder.select.start}"
    change="View1_onDateChange"/>

<Label text="{i18n>label.end.date}" required="true"/>
<DatePicker
    id="fragment_id_endDate"
    width="100%"
    valueFormat="yyyy-MM-dd"
    displayFormat="dd/MM/yyyy"
    placeholder="{i18n>placeholder.select.end}"
    change="View1_onDateChange"/>

                        <Label text="{i18n>label.hours}" required="true"/>
                    
<TimePicker
    id="fragment_id_hours"
    width="100%"
    valueFormat="HH:mm"
    displayFormat="HH:mm"
    minutesStep="1"
    placeholder="{i18n>placeholder.hours}"
    change="View1_onLiveChange"/>
                    </f:content>
                </f:SimpleForm>
            </VBox>
        </content>

        <beginButton>
            <Button
                text="{i18n>button.submit}"
                press="View1_onSaveTask"
                type="Emphasized"/>
        </beginButton>

        <endButton>
            <Button
                text="{i18n>button.cancel}"
                press="View1_onCloseDialog"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>