<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:f="sap.ui.layout.form">
    <Dialog id="taskDialog" title="{= ${params>/mode} === 'create' ? 'Create Task' : 'Update Task'}">
        <content>
            <f:SimpleForm editable="true" layout="ResponsiveGridLayout">
                <f:content>
                    <Label text="Employee Name"/>
                    <Input id="empName"/>

                    <Label text="Employee ID"/>
                    <Input id="empId"/>

                    <Label text="Task ID"/>
                    <Input id="taskId"/>

                    <Label text="Task Name"/>
                    <Input id="taskName"/>

                    <Label text="Start Date"/>
                    <DatePicker
                        id="startDate"
                        valueFormat="yyyy-MM-dd'T'HH:mm:ss.SSS'Z'"
                        displayFormat="yyyy-MM-dd"
                        placeholder="Select Start Date" />

                    <Label text="End Date"/>
                    <DatePicker
                        id="endDate"
                        valueFormat="yyyy-MM-dd'T'HH:mm:ss.SSS'Z'"
                        displayFormat="yyyy-MM-dd"
                        placeholder="Select End Date" />

                    <Label text="Hours"/>
                    <Input id="hours" type="Number"/>
                </f:content>
            </f:SimpleForm>
        </content>
        <beginButton>
            <Button text="Submit" press="onSaveTask"/>
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onCloseDialog"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>